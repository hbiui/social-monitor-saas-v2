# ==============================
# 社媒监控工具 - 环境配置文件
# ==============================

# 服务器端口（默认3000）
PORT=3000

# ==============================
# YouTube API（可选，不填则使用RSS Feed）
# ==============================
YOUTUBE_API_KEY=

# ==============================
# 邮件通知配置（可选）
# 填写后可收到邮件提醒
# ==============================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

# ==============================
# Web Push 通知密钥（自动生成，无需手动填写）
# ==============================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@social-monitor.local

# ==============================
# 监控间隔（分钟，默认30分钟）
# ==============================
CHECK_INTERVAL=30
